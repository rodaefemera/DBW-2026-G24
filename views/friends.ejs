<!DOCTYPE html>
<html lang="pt-PT">
<%- include('partials/head') %>

<body>
    <div class="container">

        <%- include('partials/header') %>

        <main class="friends-page">
            <section class="friends-layout">

                <!-- left panel with user info and add friend form -->
                <aside class="friends-left">

                    <div class="my-name-box">
                        <label for="myName">Teu nome:</label>
                        <p id="myName"><%= user.username %></p>
                    </div>

                    <!-- form to add a new friend -->
                    <form action="/friends/search" method="GET" class="friend-search-form" id="addFriendForm">
                        <label for="friendUsername">Adicionar amigo:</label>

                        <input
                            type="text"
                            id="friendUsername"
                            name="username"
                            placeholder="username"
                            autocomplete="off"
                            required
                        >

                        <button type="submit">search</button>
                    </form>

                    <!-- message area -->
                    <p id="friendMessage">
                        <% if (typeof friendMessage !== 'undefined' && friendMessage) { %>
                            <%= friendMessage %>
                        <% } %>
                    </p>

                </aside>

                <!-- right panel where friends will be shown -->
                <section class="friends-right">
                    <h1>FRIENDS</h1>

                    <!-- dynamic list, for now with js -->
                    <% if (friends.length > 0) { %>
                        <div class="friends-list" id="friendsList">
                            <% friends.forEach(friend => { %>
                                <div class="friend-card">
                                    <div class="friend-avatar"></div>
                                    <div class="friend-info">
                                        <p><a href="/profile/<%= friend.id %>" class="friend-title" style="text-decoration: none; color: inherit;">
                                            <%= friend.name %>
                                        </a></p>
                                        <span class="friend-status"><%= friend.status %></span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p>No friends yet.</p>
                    <% } %>
                </section>

            </section>
        </main>

        <%- include('partials/footer') %>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
