<!DOCTYPE html>
<html lang="pt-PT">
<%- include('partials/head') %>

<body>
    <div class="container">

        <%- include('partials/header') %>

        <main class="friends-page">
            <section class="friends-layout">

                <!-- left panel with user info and add friend form -->
                <aside class="friends-left">

                    <div class="my-name-box">
                        <label for="myName">Your Name:</label>
                        <p id="myName"><%= user.username %></p>
                    </div>

                    <!-- form to add a new friend -->
                    <form action="/friends/search" method="GET" class="friend-search-form" id="addFriendForm">
                        <label for="friendUsername">Add Friend:</label>

                        <input
                            type="text"
                            id="friendUsername"
                            name="username"
                            placeholder="username"
                            autocomplete="off"
                            required
                        >

                        <button type="submit">Search</button>
                    </form>
                    
                    <!-- message area -->
                    <p id="friendMessage">
                        <% if (typeof friendMessage !== 'undefined' && friendMessage) { %>
                            <%= friendMessage %>
                        <% } %>
                    </p>

                </aside>

                <!-- right panel where friends will be shown -->
                <section class="friends-right">
                    <h1>FRIENDS</h1>

                    <!-- dynamic list, for now with js -->
                    <% if (friends.length > 0) { %>
                        <div class="friends-list" id="friendsList">
                            <% friends.forEach(friend => { %>
                                <div class="friend-card" style="display: flex; align-items: center; margin-bottom: 15px; padding: 10px; background-color: #EDF5EE; border-radius: 8px; border: 1px solid #000;">
                                    <div class="friend-avatar" style="width: 50px; height: 50px; border-radius: 50%; overflow: hidden; background-color: #268626; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 15px;">
                                        <img src="<%= friend.profilePic %>" alt="avatar" style="width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                    <div class="friend-info" style="display: flex; flex-direction: column; justify-content: center;">
                                        <p style="margin: 0; font-size: 1.1rem;"><a href="/profile/<%= friend.id %>" class="friend-title" style="text-decoration: none; color: inherit; font-weight: bold;">
                                            <%= friend.name %>
                                        </a></p>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p>No friends yet.</p>
                    <% } %>
                </section>

            </section>
        </main>

        <%- include('partials/footer') %>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
