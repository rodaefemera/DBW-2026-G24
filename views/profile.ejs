<%- include('partials/head') %>
    <%- include('partials/header') %>

        <!-- Center -->
        <main class="page-main whitebg">
            <div class="row g-0">

                <!-- Left Panel (35%) -->
                <div class="col-12 col-lg-4 profile-left d-flex flex-column align-items-center py-5">
                    <h2 class="profile-title">Profile</h2>

                    <img src="<%= user.profilePic || 'https://upload.wikimedia.org/wikipedia/commons/7/7c/Profile_avatar_placeholder_large.png' %>"
                        class="profile-avatar" id="profileIcon" alt="Avatar"
                        style="object-fit: cover; width: 150px; height: 150px; border-radius: 50%;">

                    <div class="d-flex align-items-center justify-content-center gap-2 mt-2">
                        <p class="profile-username mb-0" id="profileName">
                            <%= user.username %>
                        </p>
                        <% if (typeof currentUser !=='undefined' && currentUser &&
                            currentUser._id.toString()===user._id.toString()) { %>
                            <span class="profile-edit-icon" id="editUsernameBtn"
                                style="cursor: pointer; color: var(--ls-accent); font-size: 1.2rem;">✎</span>
                            <% } %>
                    </div>

                    <% if (typeof currentUser !=='undefined' && currentUser &&
                        currentUser._id.toString()===user._id.toString()) { %>
                        <form action="/profile?_method=PATCH" method="POST" class="mt-3 w-100 px-4">
                            <div class="input-group input-group-sm">
                                <input type="url" name="profilePic" class="form-control" placeholder="New Photo URL"
                                    required>
                                <button type="submit" class="btn btn-outline-primary">Save</button>
                            </div>
                        </form>

                        <!-- Form for username update -->
                        <form id="editUsernameForm" action="/profile/username?_method=PATCH" method="POST"
                            style="display: none;">
                            <input type="text" name="username" id="newUsernameInput">
                        </form>
                        <% } %>
                </div>

                <!-- Right Panel (65%) -->
                <div class="col-12 col-lg-8 profile-right d-flex flex-column align-items-center py-5 px-4 px-lg-5">
                    <h2 class="profile-pb-title">Personal Best</h2>

                    <div class="profile-pb-list">
                        <div class="profile-pb-item">
                            <span class="profile-pb-mode">Time Attack:</span>
                            <span class="profile-pb-score" id="scoreTimeAttack">
                                <%= user.scoreTime %>
                            </span>
                        </div>

                        <div class="profile-pb-item">
                            <span class="profile-pb-mode">1st 2 3:</span>
                            <span class="profile-pb-score" id="scoreFirst23">
                                <%= user.score123 %>
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </main>
        <%- include('partials/footer') %>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
                crossorigin="anonymous"></script>

            <script>
                <% if (typeof error !== 'undefined' && error) { %>
                    alert("<%= error %>");
                <% } %>

                const editBtn = document.getElementById('editUsernameBtn');
                if (editBtn) {
                    editBtn.addEventListener('click', () => {
                        const newName = prompt("Enter new username:", "<%= user.username %>");
                        if (newName && newName.trim() !== "" && newName !== "<%= user.username %>") {
                            if (newName.trim().length > 15) {
                                alert("Username cannot exceed 15 characters.");
                                return;
                            }
                            document.getElementById('newUsernameInput').value = newName.trim();
                            document.getElementById('editUsernameForm').submit();
                        }
                    });
                }
            </script>
            </body>

            </html>