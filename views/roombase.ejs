<!DOCTYPE html>
<html lang="pt-PT">
<%- include('partials/head') %>
<body>
    <div class="container">
        <header>
            <div class="top room-top">
                <a href="/" class="bigword">MATRIOSCA</a>
                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <span class="room-user-inline"><%= currentUser.username %></span>
                <% } else { %>
                    <a href="/login" class="authentication">Log In</a>
                    <a href="/signup" class="authentication">Sign up</a>
                <% } %>
            </div>
            <nav class="navegacao">
                <a href="/profile">Profile</a>
                <a href="/friends">Friends</a>
                <a href="/roomlist">Rooms</a>
                <a href="/leaderboards">Leaderboard</a>
                <a href="/feedback">Feedback</a>
            </nav>
        </header>

        <main class="room-page">
            <section class="room-mode-bar">
                <h1 id="gameMode">Time Attack</h1>
                <a href="/roomlist" class="leave-room-link">Leave Room</a>
            </section>
            <section class="room-main-layout">
                <aside class="room-players-panel">
                    <h2>Players</h2>
                    <div id="playersList"></div>
                </aside>
                <section class="room-game-panel">
                    <div class="room-word-box">
                        <h2 id="mainWord">PALAVRA</h2>
                        <div id="answersList" class="room-answers"></div>
                        <div class="room-mode-info">
                            <p id="modeInfo">Tempo restante: 60s</p>
                        </div>
                        <form action="/guess" method="POST" id="guessForm" class="room-guess-form">
                            <input type="text" name="guess" id="guessInput" placeholder="Type ur guess here.." required>
                            <button type="submit">Send</button>
                        </form>
                    </div>
                    <div class="room-score-box">
                        <p id="scoreText">Score: 100 Points</p>
                    </div>
                    <div class="room-code-inline">
                        Room Code: #XYZ-123
                    </div>
                </section>
                <aside class="room-chat-panel">
                    <h2>chat</h2>
                    <div id="chatBox" class="room-chat-messages">
                        <p>[username]: hello</p>
                        <p>[username2]: hello2</p>
                    </div>
                    <form action="/chat" method="POST" id="chatForm" class="room-chat-form">
                        <input type="text" name="message" id="chatInput" placeholder="Chat here.." required>
                        <button type="submit">Send</button>
                    </form>
                </aside>
            </section>
        </main>
        <%- include('partials/footer') %>
    </div>
    <script src="/js/roombase.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
